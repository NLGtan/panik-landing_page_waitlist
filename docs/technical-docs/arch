### 3. Protocol Safety (20%)

Static config — hardcoded, no runtime query. Update manually on new events.

```python
# Higher raw_safety = safer protocol
# S_protocol_safety = 100 - raw_safety  (inverted to risk scale)

PROTOCOL_SAFETY = {
  "aave_v3": {
    "audit_score":        90,  # multiple top-tier audits
    "exploit_score":      95,  # no protocol-level insolvency
    "tvl_stability":      85,
    "governance":         85,
    "weights": [0.35, 0.35, 0.20, 0.10]
    # expected S_protocol_safety ≈ 11 (Low)
  },
  "moonwell": {
    "audit_score":        60,
    "exploit_score":      40,  # 2 exploits in 8mo (Nov 2025, Feb 2026)
    "tvl_stability":      65,
    "governance":         60,
    "weights": [0.35, 0.35, 0.20, 0.10]
    # expected S_protocol_safety ≈ 46 (Elevated)
  }
}

def compute_protocol_safety(protocol: str) -> float:
    p = PROTOCOL_SAFETY[protocol]
    w = p["weights"]
    raw = w[0]*p["audit_score"] + w[1]*p["exploit_score"] \
        + w[2]*p["tvl_stability"] + w[3]*p["governance"]
    return round(100 - raw, 2)
```

