# PANIK environment template — copy to .env and fill in.
# .env is gitignored; NEVER commit real keys.
#
# IMPORTANT: only VITE_-prefixed vars are exposed to the frontend bundle.
# Everything else is backend-only. Do not add secrets with a VITE_ prefix.

# ── Slice 1 (scoring engine) ────────────────────────────────────────────
# CoinGecko Demo plan key (free, 30 calls/min) — asset risk price history
# Get: coingecko.com → API → Demo plan signup
COINGECKO_API_KEY=

# Dune API key (free tier) — week-1 calibration data pulls, analytics only
# Get: dune.com → Settings → API
DUNE_API_KEY=

# ── Slice 2 (active mode + wallet) ──────────────────────────────────────
# Alchemy app keys (free tier) — Base mainnet reads + Base Sepolia testnet
# Get: alchemy.com → create app per network
ALCHEMY_API_KEY_BASE_MAINNET=
ALCHEMY_API_KEY_BASE_SEPOLIA=

# WalletConnect / Reown Cloud project ID (free) — wagmi connect modal.
# Public by design, hence the VITE_ prefix.
# Get: cloud.reown.com → create project
VITE_WALLETCONNECT_PROJECT_ID=

# DefiLlama: no key required. Chainlink: read on-chain via Alchemy RPC.

# ── Goldsky (event indexing — Advisor "what happened" feed + reconciliation) ──
# Free Starter tier: 3 subgraph workers, 100k entities, 1 Mirror pipeline,
# 1M records/mo. Get: app.goldsky.com → create project → Settings → API keys.
# API key is used by the CLI (`goldsky login`) and pipeline/webhook config;
# the project ID scopes deployments. Backend-only — never VITE_-prefix these.
GOLDSKY_PROJECT_ID=
GOLDSKY_API_KEY=