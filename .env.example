# PANIK environment template — copy to .env and fill in.
# .env is gitignored; NEVER commit real keys.
#
# IMPORTANT: only VITE_-prefixed vars are exposed to the frontend bundle.
# Everything else is backend-only. Do not add secrets with a VITE_ prefix.

# ── Slice 1 (scoring engine) ────────────────────────────────────────────
# CoinGecko Demo plan key (free, 30 calls/min) — asset risk price history
# Get: coingecko.com → API → Demo plan signup
COINGECKO_API_KEY=

# Dune API key (free tier) — week-1 calibration data pulls, analytics only.
# ALSO powers the wallet DeFi-persona profiler (/api/profile): lifetime
# cross-chain lending history via saved query 7771860. See
# docs/technical-docs/WALLET_PROFILER.md.
# Get: dune.com → Settings → API
DUNE_API_KEY=

# OpenRouter key — AI narration for the persona profiler (model
# google/gemini-2.5-flash). OPTIONAL: if blank, /api/profile still works and
# returns deterministic fallback prose. Backend-only — never VITE_-prefix.
# Get: openrouter.ai → Keys
OPENROUTER_API_KEY=

# ── Slice 2 (active mode + wallet) ──────────────────────────────────────
# Alchemy app keys (free tier) — Base mainnet reads + Base Sepolia testnet
# Get: alchemy.com → create app per network
ALCHEMY_API_KEY_BASE_MAINNET=
ALCHEMY_API_KEY_BASE_SEPOLIA=

# WalletConnect / Reown Cloud project ID (free) — wagmi connect modal.
# Public by design, hence the VITE_ prefix.
# Get: cloud.reown.com → create project
VITE_WALLETCONNECT_PROJECT_ID=

# DefiLlama: no key required. Chainlink: read on-chain via Alchemy RPC.

# ── Supabase (data + auth layer — waitlist CRM, watch state, Mirror sink) ──
# Get all of these: supabase.com → your project → Project Settings.
#
# Frontend (public by design — RLS is the security boundary, not the key):
# Settings → API → Project URL + publishable key
# (older projects call it "anon" key; either works in these slots)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Backend/worker only (SECRET — bypasses RLS; never VITE_-prefix, never
# ship to a browser). Settings → API → secret key ("service_role" on
# older projects). Used by the Watch worker + Edge Function admin tasks.
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Postgres connection string (SECRET) — dashboard → Connect → use the
# ⚠ SESSION POOLER string (port 5432, host aws-X-[region].pooler.supabase.com,
# user postgres.[PROJECT-REF]). Why not the others:
#   - "Direct connection" (db.[ref].supabase.co) is IPv6-ONLY on new
#     projects → ENOTFOUND from IPv4-only networks (verified 2026-06-13)
#   - Transaction pooler (port 6543) breaks long-lived connections
# Session pooler = IPv4-compatible AND holds connections → works for both
# the Goldsky Mirror sink and the Watch worker. Same DB password.
# NOTE: the api-server AND the Watch worker call transactionPoolerUrl(), which
# auto-rewrites this string's port 5432 -> 6543 (the transaction pooler) because
# the session pooler times out from some networks. Paste the session-pooler
# string here; the rewrite is transparent. Set SUPABASE_DB_POOL_URL to override.
SUPABASE_DB_URL=

# ── Goldsky (event indexing — Advisor "what happened" feed + reconciliation) ──
# Free Starter tier: 3 subgraph workers, 100k entities, 1 Mirror pipeline,
# 1M records/mo. Get: app.goldsky.com → create project → Settings → API keys.
# API key is used by the CLI (`goldsky login`) and pipeline/webhook config;
# the project ID scopes deployments. Backend-only — never VITE_-prefix these.
GOLDSKY_PROJECT_ID=
GOLDSKY_API_KEY=

# ── Slice 3 (Telegram near-liquidation alerts) ─────────────────────────
# Bot token from @BotFather. BACKEND/WORKER ONLY - never VITE_-prefix.
# Used by the Watch worker (sends alerts) and the webhook (replies).
TELEGRAM_BOT_TOKEN=
# A random string you choose; passed to setWebhook as secret_token and checked
# on every incoming update (X-Telegram-Bot-Api-Secret-Token). Backend-only.
TELEGRAM_WEBHOOK_SECRET=
# Bot username (no @) for the deep-link t.me/<username>?start=<code>. Public by
# design (it is in the link), hence VITE_. Read by /api/telegram/link too.
VITE_TELEGRAM_BOT_USERNAME=
# Production base URL for the one-time `npm run telegram:setup` (setWebhook),
# e.g. https://panik.xyz. Not needed at runtime. Can be passed as a CLI arg.
TELEGRAM_PUBLIC_BASE_URL=

# ── Founding User Escrow (hidden page — /founding) ─────────────────────
# Contract address on Base (deployed via `forge script` — see contracts/README.md).
# Public by design (readable on Basescan), hence the VITE_ prefix.
VITE_ESCROW_CONTRACT_ADDRESS=0xa69ed7807d5a5791bb31233d0cb275408337347b48cde76b05e80e7824eb2883
# Chain ID: 8453 (Base mainnet) or 84532 (Base Sepolia for testing).
VITE_ESCROW_CHAIN_ID=84532