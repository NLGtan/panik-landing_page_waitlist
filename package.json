{
  "name": "panik",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test:scoring": "npm run test --workspace=@panik/scoring",
    "ping:apis": "node --env-file=.env scripts/ping-apis.mjs",
    "demo:scores": "node --env-file=.env --import tsx scripts/score-demo.ts",
    "demo:watch": "node --env-file=.env --import tsx scripts/watch-demo.ts",
    "db:verify": "node --env-file=.env scripts/verify-schema.mjs",
    "dev:api": "node --watch --env-file=.env --import tsx scripts/api-server.ts"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "pg": "^8.21.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
